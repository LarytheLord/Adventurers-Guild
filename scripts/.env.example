# Reddit API credentials (create at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=AdventurersGuildLeadMachine/1.0

# Email/SMTP settings for digest
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
DIGEST_FROM=Adventurers Guild <noreply@adventurersguild.com>
DIGEST_TO=admin@adventurersguild.com

# Optional: Resend API key (used if SMTP is not configured)
# RESEND_API_KEY=re_xxx

# Run mode: dry-run or live
# REDDIT_MODE=dry-run
